# ionic_write_safety.rules
# Technology: ionic | Capability: write

rule ionic-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_ionic_PATTERN"
  MESSAGE "Blocked an unsafe pattern in ionic. Use the recommended best practices for 2025/2026."
}

rule ionic-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_ionic_API"
  MESSAGE "You are using an outdated API for ionic. Please upgrade to the newer API."
}
